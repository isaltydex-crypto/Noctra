#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
duration="${2:-30}"

install -d -m 0755 /etc/noctra

usage() {
  printf 'Usage: %s tor-locked | clearnet-unlock [minutes]\n' "$0" >&2
}

case "$mode" in
  tor-locked)
    nft -f /etc/noctra/nftables/tor-locked.nft
    printf '%s\n' 'tor-locked' > /etc/noctra/network-mode
    logger -t noctra-network-mode "Switched to Tor Locked"
    ;;
  clearnet-unlock)
    if ! [[ "$duration" =~ ^[0-9]+$ ]]; then
      usage
      exit 2
    fi
    nft -f /etc/noctra/nftables/clearnet-unlock.nft
    printf '%s\n' 'clearnet-unlock' > /etc/noctra/network-mode
    logger -t noctra-network-mode "Clearnet Unlock enabled for ${duration} minutes"
    systemd-run --on-active="${duration}m" --unit=noctra-relock-network /usr/local/bin/noctra-network-mode tor-locked >/dev/null
    ;;
  *)
    usage
    exit 2
    ;;
esac
