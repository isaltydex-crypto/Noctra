#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
duration="${2:-30}"
state_dir="/etc/noctra"
state_file="${state_dir}/network-mode"
relock_unit="noctra-relock-network"

usage() {
  cat >&2 <<EOF
Usage:
  noctra-network-mode status
  noctra-network-mode tor-locked
  noctra-network-mode clearnet-unlock [minutes]

Examples:
  noctra-network-mode status
  sudo noctra-network-mode clearnet-unlock 10
  sudo noctra-network-mode tor-locked
EOF
}

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    printf 'This action requires root. Re-run with sudo.\n' >&2
    exit 1
  fi
}

write_mode() {
  install -d -m 0755 "${state_dir}"
  printf '%s\n' "$1" > "${state_file}"
}

cancel_relock_timer() {
  systemctl stop "${relock_unit}.timer" "${relock_unit}.service" >/dev/null 2>&1 || true
  systemctl reset-failed "${relock_unit}.timer" "${relock_unit}.service" >/dev/null 2>&1 || true
}

validate_duration() {
  if ! [[ "$duration" =~ ^[0-9]+$ ]]; then
    printf 'Duration must be a number of minutes.\n' >&2
    exit 2
  fi

  if (( duration < 1 || duration > 240 )); then
    printf 'Duration must be between 1 and 240 minutes.\n' >&2
    exit 2
  fi
}

show_status() {
  local current="unknown"
  local tor_state="unknown"
  local nft_state="unknown"
  local timer_state="inactive"

  if [[ -r "${state_file}" ]]; then
    current="$(<"${state_file}")"
  fi

  if command -v systemctl >/dev/null 2>&1; then
    tor_state="$(systemctl is-active tor.service 2>/dev/null || true)"
    timer_state="$(systemctl is-active "${relock_unit}.timer" 2>/dev/null || true)"
  fi

  if command -v nft >/dev/null 2>&1 && nft list table inet noctra_filter >/dev/null 2>&1; then
    nft_state="loaded"
  else
    nft_state="missing"
  fi

  printf 'mode=%s\n' "${current}"
  printf 'tor=%s\n' "${tor_state:-unknown}"
  printf 'nftables=%s\n' "${nft_state}"
  printf 'relock_timer=%s\n' "${timer_state:-inactive}"
}

case "$mode" in
  status)
    show_status
    ;;
  tor-locked)
    require_root
    cancel_relock_timer
    nft -f /etc/noctra/nftables/tor-locked.nft
    write_mode "tor-locked"
    logger -t noctra-network-mode "Switched to Tor Locked"
    ;;
  clearnet-unlock)
    require_root
    validate_duration
    cancel_relock_timer
    nft -f /etc/noctra/nftables/clearnet-unlock.nft
    write_mode "clearnet-unlock"
    logger -t noctra-network-mode "Clearnet Unlock enabled for ${duration} minutes"
    systemd-run --on-active="${duration}m" --unit="${relock_unit}" --collect /usr/local/bin/noctra-network-mode tor-locked >/dev/null
    ;;
  *)
    usage
    exit 2
    ;;
esac
