# Maintainer: Noctra OS
pkgname=noctra-base
pkgver=0.1.0
pkgrel=1
pkgdesc="Noctra OS base system defaults"
arch=('any')
url="https://github.com/isaltydex-crypto/Noctra"
license=('GPL-3.0-or-later')
depends=(
  'amd-ucode'
  'base'
  'cryptsetup'
  'intel-ucode'
  'linux'
  'linux-firmware'
  'networkmanager'
  'noctra-network'
  'sudo'
)
source=('noctra-health-check')
sha256sums=('SKIP')

package() {
  install -dm755 "${pkgdir}/etc/noctra"
  printf '%s\n' 'tor-locked' > "${pkgdir}/etc/noctra/network-mode"
  install -Dm755 noctra-health-check "${pkgdir}/usr/bin/noctra-health-check"
}
